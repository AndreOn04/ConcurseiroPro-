generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? 
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  materias    Materia[]
  sessoes     SessaoEstudo[]
  cronogramas CronogramaItem[]
  tentativas  SimulacaoTentativa[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Materia {
  id        String   @id @default(cuid())
  nome      String
  cor       String   @default("#6366f1")
  userId    String
  createdAt DateTime @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicos     Topico[]
  sessoes     SessaoEstudo[]
  cronogramas CronogramaItem[]
}

model Topico {
  id        String   @id @default(cuid())
  nome      String
  concluido Boolean  @default(false)
  materiaId String
  createdAt DateTime @default(now())

  materia Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
}

model SessaoEstudo {
  id        String   @id @default(cuid())
  duracao   Int
  userId    String
  materiaId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  materia Materia? @relation(fields: [materiaId], references: [id])
}

model CronogramaItem {
  id         String   @id @default(cuid())
  titulo     String
  diaSemana  Int
  horaInicio String
  horaFim    String
  userId     String
  materiaId  String?
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  materia Materia? @relation(fields: [materiaId], references: [id])
}

model Simulacao {
  id        String   @id @default(cuid())
  titulo    String
  createdAt DateTime @default(now())

  questoes   Questao[]
  tentativas SimulacaoTentativa[]
}

model Questao {
  id           String @id @default(cuid())
  enunciado    String
  alternativas Json
  gabarito     Int
  simulacaoId  String

  simulacao Simulacao @relation(fields: [simulacaoId], references: [id], onDelete: Cascade)
  respostas Resposta[]
}

model SimulacaoTentativa {
  id          String   @id @default(cuid())
  userId      String
  simulacaoId String
  pontuacao   Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulacao Simulacao @relation(fields: [simulacaoId], references: [id])
  respostas Resposta[]
}

model Resposta {
  id          String @id @default(cuid())
  questaoId   String
  tentativaId String
  resposta    Int

  questao   Questao            @relation(fields: [questaoId], references: [id])
  tentativa SimulacaoTentativa @relation(fields: [tentativaId], references: [id], onDelete: Cascade)
}